# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
GUILD_ID=                # for fast guild-scoped command deploy during dev; leave blank for global
ADMIN_ROLE_ID=           # role that can resolve disputes / run /mm admin
TICKET_CATEGORY_ID=      # discord category where ticket channels get created

# Database (Neon Postgres)
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# HD Wallet - master seed phrase. GENERATE ONCE, BACK UP OFFLINE, NEVER COMMIT.
# You can generate one with: node src/gen-mnemonic.js
MASTER_MNEMONIC=

# RPC endpoints (defaults are free public ones, swap for your own if rate limited)
ETH_RPC_URL=https://eth.llamarpc.com
BSC_RPC_URL=https://bsc-dataseed.binance.org
SOL_RPC_URL=https://api.mainnet-beta.solana.com
BLOCKCYPHER_TOKEN=       # optional, raises rate limit for BTC/LTC lookups

# USDT BEP20 contract on BSC
USDT_BEP20_CONTRACT=0x55d398326f99059fF775485246999027B3197955

# Central hot wallet (funds get swept here after confirm, payouts sent from here)
# Leave blank to auto-derive at index 0 for each coin from MASTER_MNEMONIC
HOT_WALLET_INDEX=0

# Fee wallet destination (where collected fees accumulate) - defaults to hot wallet if blank
FEE_WALLET_ADDRESS_BTC=
FEE_WALLET_ADDRESS_LTC=
FEE_WALLET_ADDRESS_ETH=
FEE_WALLET_ADDRESS_SOL=
FEE_WALLET_ADDRESS_USDT_BEP20=

PORT=3000
